{
  "ci": {
    "collect": {
      "url": [
        "http://127.0.0.1:8000/",
        "http://127.0.0.1:8000/help",
        "http://127.0.0.1:8000/traceroute"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--no-sandbox --headless=new"
      }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:performance": "off",
        "categories:seo": "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
